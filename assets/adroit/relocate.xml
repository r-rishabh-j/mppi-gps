<mujoco model='ADROIT-relocate(v1.5)'>

    <!-- ======= WORLD ======= -->
    <worldbody>
        <light directional='false' diffuse='.7 .7 .7' specular='0.03 0.03 0.03' pos='-1 -1.0 4.0' dir='1 1.0 -4'/>
        <geom name='ground' size="1.5 1.5 0.25" pos="0 0 -1" type="plane" contype="1" conaffinity="0" material="groundplane" />
        <camera name="fixed" pos="0 -0.7 0.7" quat="0.92388 0.382683 0 0" />
        <!-- Camera for the VIL paper -->
        <camera name="vil_camera" pos="0 -1.2 1.2" quat="0.92388 0.382683 0 0" />
        <!-- Multi-angle cameras for the recording path. mode="targetbody"
             auto-orients the camera toward the target_body, so the
             green destination stays centred. Targeting the Object
             instead jitters the view as the ball is grasped/lifted —
             stable framing is more useful for inspecting behaviour. -->
        <camera name="cam_top"  pos="0  -0.2 0.9"  mode="targetbody" target="target_body"/>
        <camera name="cam_side" pos="0.7 -0.2 0.25" mode="targetbody" target="target_body"/>
        <camera name="cam_iso"  pos="0.5 -0.7 0.5"  mode="targetbody" target="target_body"/>

        <!-- ======= TABLE ======= -->
        <body name="table">
            <!-- <geom size="0.5 0.5 0.025" type="plane" material="table2d" /> --> <!-- Plane has better contacts -->
            <geom size="0.45 0.45 0.025" pos="0 0 -0.025" type="box" material="tablecube" />
            <geom size="0.04 0.5" pos="0.4 0.4 -0.501" quat="0 1 0 0" type="cylinder" contype="0" conaffinity="0" />
            <geom size="0.04 0.5" pos="-0.4 0.4 -0.501" quat="0 1 0 0" type="cylinder" contype="0" conaffinity="0" />
            <geom size="0.04 0.5" pos="0.4 -0.4 -0.501" quat="0 1 0 0" type="cylinder" contype="0" conaffinity="0" />
            <geom size="0.04 0.5" pos="-0.4 -0.4 -0.501" quat="0 1 0 0" type="cylinder" contype="0" conaffinity="0" />
            <!-- Containment walls: thin invisible boxes along the table edges
                 so the ball cannot be flung / pushed off during MPPI
                 exploration or policy rollouts. ±0.42 sits 2cm inside the
                 table edge (±0.45) and 2cm outside the worst-case palm
                 reach (~±0.4 from ARTx ±0.25 + palm extent). Height
                 0.05m so a ball of radius 0.035 can't bounce over even
                 at high velocity. rgba alpha=0 keeps the visual matching
                 D4RL/DAPG screenshots — bump alpha (e.g. "1 0 0 0.3")
                 while debugging to see the walls. -->
            <geom name="wall_xpos" type="box" size="0.003 0.42 0.05"
                  pos="0.42 0 0.05"  rgba="0 0 0 0" contype="1" conaffinity="1"/>
            <geom name="wall_xneg" type="box" size="0.003 0.42 0.05"
                  pos="-0.42 0 0.05" rgba="0 0 0 0" contype="1" conaffinity="1"/>
            <geom name="wall_ypos" type="box" size="0.42 0.003 0.05"
                  pos="0 0.42 0.05"  rgba="0 0 0 0" contype="1" conaffinity="1"/>
            <geom name="wall_yneg" type="box" size="0.42 0.003 0.05"
                  pos="0 -0.42 0.05" rgba="0 0 0 0" contype="1" conaffinity="1"/>
        </body>

        <!-- ======= MOCAP ======= -->
        <body name="vive_tracker" pos="0 -0.35 0.25" mocap="true">
            <inertial pos="0 0 0" mass="0.064" diaginertia="1.70667e-05 1.70667e-05 1.70667e-05" />
            <geom size="0.03 0.01" type="cylinder" contype="0" conaffinity="0" group="3" rgba="0.3 0.3 0.3 0.3" />
        </body>

        <!-- ======= HAND ======= -->
        <body name="forearm" pos="0 -0.7 0.2" euler="-1.57 0 3.14">
            <inertial pos="0.001 -0.002 0.29" quat="0.982037 -0.0160006 0 -0.188007" mass="4" diaginertia="0.01 0.01 0.0075" />
            <joint name="ARTx" pos="0 0 0" axis="1 0 0" type="slide" range="-0.25 0.25" damping="20" />
            <joint name="ARTy" pos="0 0 0" axis="0 1 0" type="slide" range="0 0.2" damping="20" />
            <joint name="ARTz" pos="0 0 0" axis="0 0 1" type="slide" range="-0.3 0.5" damping="20" />
            <joint name="ARRx" pos="0 0 0" axis="1 0 0" range="-.75 .75" damping="20" />
            <joint name="ARRy" pos="0 0 0" axis="0 1 0" range="-.75 .75" damping="20" />
            <joint name="ARRz" pos="0 0 0" axis="0 0 1" range="-.75 .75" damping="20" />
            <geom name="V_forearm" class="D_Vizual" pos="0 -.01 .181" euler="0 0 -1.57"  mesh="forearm_simple" />
            <geom name="C_forearm1" class="DC_Hand" size="0.05 0.033" pos="0 0 0.29" type="capsule" rgba="0.4 0.5 0.6 0.1" />
            <!-- ======= Adroit ======= -->
            <include file="adroit_model.xml"/>
        </body>

        <!-- ======= DESTINATION ======= -->
        <!-- Wrap the target site in a body so the recording cameras can
             use mode="targetbody" target="target_body" — that mode only
             supports bodies, not sites. The body's pos is randomised at
             reset (env writes model.body_pos); the site sits at body-
             local origin and is purely visual. -->
        <body name="target_body" pos="-0.007 0.0 0.2">
            <inertial pos="0 0 0" mass="0.001" diaginertia="1e-9 1e-9 1e-9" />
            <site name="target" pos="0 0 0" size="0.07" rgba="0 1 0 0.125" />
        </body>

        <!-- ======= OBJECT ======= -->
        <body name="Object" pos="-0.00 0.0 0.035" user="1001 0 2003 27 0 0 0.06 0 0">
            <inertial pos="0 0 0" mass="0.179594" diaginertia="8.80012e-05 8.80012e-05 8.80012e-05" />
            <joint name="OBJTx" pos="0 0 0" axis="1 0 0" type="slide" limited="false" damping="0" />
            <joint name="OBJTy" pos="0 0 0" axis="0 1 0" type="slide" limited="false" damping="0" />
            <joint name="OBJTz" pos="0 0 0" axis="0 0 1" type="slide" limited="false" damping="0" />
            <joint name="OBJRx" pos="0 0 0" axis="1 0 0" limited="false" damping="0" />
            <joint name="OBJRy" pos="0 0 0" axis="0 1 0" limited="false" damping="0" />
            <joint name="OBJRz" pos="0 0 0" axis="0 0 1" limited="false" damping="0" />
            <geom name="sphere" size="0.035" condim="4" material="MatWoodB" />
            <!-- Site at body origin so a framepos sensor can read xpos[Object]
                 (framepos objtype=body returns xipos = inertial frame, not
                 the body frame). The geom itself sits at body origin so this
                 site coincides with both. -->
            <site name="object_origin" type="sphere" size="0.001" pos="0 0 0" rgba="0 0 0 0"/>
        </body>
    </worldbody>

    <actuator>
        <general name="A_ARTx" joint="ARTx" ctrlrange="-0.25 0.25" biastype="affine" gainprm="500 0 0" biasprm="0 -200 0" />
        <general name="A_ARTy" joint="ARTy" ctrlrange="0.0 0.2" biastype="affine" gainprm="500 0 0" biasprm="0 -200 0" />
        <general name="A_ARTz" joint="ARTz" ctrlrange="-0.3 0.5" biastype="affine" gainprm="500 0 0" biasprm="0 -200 0" />
        <general name="A_ARRx" joint="ARRx" ctrlrange="-.75 .75" biastype="affine" gainprm="500 0 0" biasprm="0 -200 0" />
        <general name="A_ARRy" joint="ARRy" ctrlrange="-.75 .75" biastype="affine" gainprm="500 0 0" biasprm="0 -200 0" />
        <general name="A_ARRz" joint="ARRz" ctrlrange="-.75 .75" biastype="affine" gainprm="500 0 0" biasprm="0 -200 0" />
    </actuator>

    <include file='adroit_assets.xml'/>

    <!-- ======= Sensors added for MPPI cost computation ======= -->
    <!-- object_pos: world position of the Object body frame origin
         (matches upstream's data.xpos[Object]).
         palm_pos: world position of the S_grasp site (matches upstream's
         data.site_xpos[S_grasp]). The target site's world position is
         randomised at reset and constant during a rollout, so the env
         caches it as a python attribute rather than a sensor. -->
    <sensor>
        <framepos name="object_pos" objtype="site" objname="object_origin"/>
        <framepos name="palm_pos"   objtype="site" objname="S_grasp"/>
        <!-- Virtual reach target ~5cm above the palm surface (palm-side,
             where curled fingers reach); see S_reach in adroit_model.xml. -->
        <framepos name="reach_pos"  objtype="site" objname="S_reach"/>
        <!-- Fingertip world positions: used by the cost to per-finger gate
             the touch-based grip bonus by proximity to the ball, so
             fingertips touching the table earn nothing. -->
        <framepos name="fftip_pos" objtype="site" objname="S_fftip"/>
        <framepos name="mftip_pos" objtype="site" objname="S_mftip"/>
        <framepos name="rftip_pos" objtype="site" objname="S_rftip"/>
        <framepos name="lftip_pos" objtype="site" objname="S_lftip"/>
        <framepos name="thtip_pos" objtype="site" objname="S_thtip"/>
    </sensor>

</mujoco>
